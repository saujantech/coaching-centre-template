# Vercel serverless functions only — never expose these client-side.
# Set the real values in the Vercel project's Environment Variables settings.

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=your-resend-api-key

# Optional: protects /api/send-reminders from being triggered by anyone
# who guesses the URL. Set the same value in Vercel Cron's headers if you
# use one, or leave unset to skip the check.
CRON_SECRET=some-long-random-string
